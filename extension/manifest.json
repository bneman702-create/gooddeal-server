{
  "manifest_version": 3,
  "name": "GoodDeal? — Price Checker",
  "version": "1.0.0",
  "description": "Instantly check if you're getting a good deal. AI-powered price comparison on any shopping site.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://*.amazon.com/*",
    "https://*.ebay.com/*",
    "https://*.walmart.com/*",
    "https://*.target.com/*",
    "https://*.bestbuy.com/*",
    "https://*.costco.com/*",
    "https://*.newegg.com/*",
    "https://*.etsy.com/*",
    "https://*.wayfair.com/*",
    "https://*.nike.com/*",
    "https://*.adidas.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "GoodDeal? — Check this price"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.amazon.com/*",
        "https://*.ebay.com/*",
        "https://*.walmart.com/*",
        "https://*.target.com/*",
        "https://*.bestbuy.com/*",
        "https://*.costco.com/*",
        "https://*.newegg.com/*",
        "https://*.etsy.com/*",
        "https://*.wayfair.com/*",
        "https://*.nike.com/*",
        "https://*.adidas.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
